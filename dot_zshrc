ssm_port_forward() {
  local INSTANCE_ID="$1"
  local REMOTE_HOST="$2"
  local REMOTE_PORT="$3"
  local LOCAL_PORT="$4"

  export TMPDIR=/tmp/$INSTANCE_ID
  mkdir -p "$TMPDIR"
  aws ssm start-session \
    --target "$INSTANCE_ID" \
    --document-name AWS-StartPortForwardingSessionToRemoteHost \
    --parameters "{\"host\":[\"$REMOTE_HOST\"],\"portNumber\":[\"$REMOTE_PORT\"],\"localPortNumber\":[\"$LOCAL_PORT\"]}"
}

connectToProdClickHouse() {
  ssm_port_forward \
    i-08e287e34a3273018 \
    10.8.155.185 \
    8123 \
    8123
}

